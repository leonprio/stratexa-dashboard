rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 🛡️ NUCLEAR ISOLATION FUNCTIONS ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // Validador de Super Admin Hardcodeado
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email in [
        'leon@leonprior.com',
        'leonprior@gmail.com',
        'admin-backup@prior.com',
        'admin@test.com'
      ];
    }

    // Validador de Pertenencia: Un usuario solo accede a su propia burbuja o si es SuperAdmin
    function isTableroUser() {
      return isSuperAdmin() || exists(/databases/$(database)/documents/tbl_users/$(request.auth.uid));
    }
    function isGobernanzaUser() {
      return isAuthenticated(); // Legacy permit: don't break Governance app
    }
    
    function isVacantesUser() {
      return isAuthenticated(); // Legacy permit: don't break Vacancy app
    }
    
    function isActivadorUser() {
      return isAuthenticated(); // Legacy permit: don't break Activador app
    }

    // --- 1. AISLAMIENTO: TABLERO (tbl_*) ---
    match /tbl_users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isTableroUser());
    }
    match /tbl_dashboards/{docId} {
      allow read, write: if isTableroUser();
      match /items/{itemId} { allow read, write: if isTableroUser(); }
    }
    match /tbl_systemSettings/{id=**} { allow read, write: if isTableroUser(); }
    match /tbl_managedClients/{id=**} { allow read, write: if isTableroUser(); }

    // --- 2. AISLAMIENTO: GOBERNANZA (cpx_*) ---
    // Gobernanza usa cpx_ para proteger su integridad
    match /cpx_users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isGobernanzaUser());
    }
    match /cpx_work_plans/{id=**} { allow read, write: if isGobernanzaUser(); }
    match /cpx_indicators/{id=**} { allow read, write: if isGobernanzaUser(); }
    match /cpx_reports/{id=**} { allow read, write: if isGobernanzaUser(); }

    // --- 3. AISLAMIENTO: VACANTES (vac_*) ---
    // Nueva burbuja aislada de Activador
    match /vac_users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isVacantesUser());
    }
    match /vac_weekly_data/{id=**} { allow read, write: if isVacantesUser(); }
    match /vac_weekly_analysis/{id=**} { allow read, write: if isVacantesUser(); }
    match /vac_config/{id=**} { allow read, write: if isVacantesUser(); }
    match /vac_unes/{id=**} { allow read, write: if isVacantesUser(); }

    match /stx_users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isActivadorUser());
    }
    match /stx_dashboards/{id=**} { allow read, write: if isActivadorUser(); }
    match /stx_history/{id=**} { allow read, write: if isActivadorUser(); }
    match /stx_managedClients/{id=**} { allow read, write: if isActivadorUser(); }
    match /stx_weekly_data/{id=**} { allow read, write: if isActivadorUser(); }
    match /stx_weekly_analysis/{id=**} { allow read, write: if isActivadorUser(); }
    match /stx_config/{id=**} { allow read: if isAuthenticated(); allow write: if isActivadorUser(); }
    match /stx_unes/{id=**} { allow read: if isAuthenticated(); allow write: if isActivadorUser(); }

    // --- 5. COMPATIBILIDAD Y LEGACY (Bloqueo Gradual) ---
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }
    
    // Bloqueo de colecciones genéricas (Aislamiento progresivo)
    // Permite lectura a todas las apps legacy, pero lo restringe a que sean usuarios reconocidos en al menos una app
    match /dashboards/{id=**} { allow read, write: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /weekly_data/{id=**} { allow read, write: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /weekly_analysis/{id=**} { allow read, write: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /config/{id=**} { allow read, write: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /unes/{id=**} { allow read, write: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /systemSettings/{id=**} { allow read, write: if isTableroUser() || isActivadorUser(); }
    match /managedClients/{id=**} { allow read, write: if isTableroUser() || isActivadorUser(); }
    match /history/{id=**} { allow read, write: if isTableroUser() || isActivadorUser(); }
    match /clients/{id=**} { allow read: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /groups/{id=**} { allow read: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /indicators/{id=**} { allow read: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /directorates/{id=**} { allow read: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /addresses/{id=**} { allow read: if isTableroUser() || isGobernanzaUser() || isActivadorUser() || isVacantesUser(); }
    match /ips_config/{id=**} { allow read: if isTableroUser() || isActivadorUser(); }
    match /ips_users/{id=**} { allow read: if isTableroUser() || isActivadorUser(); }
    match /ips_weekly_data/{id=**} { allow read, write: if isTableroUser() || isActivadorUser(); }
    match /ips_weekly_analysis/{id=**} { allow read, write: if isTableroUser() || isActivadorUser(); }


    // --- 🚨 REGLA DE COMPATIBILIDAD UNIVERSAL (AISLAMIENTO INTELIGENTE) 🚨 ---
    // En lugar de un cierre nuclear ciego, permitimos acceso a cualquier colección
    // QUE NO SEA parte del nuevo esquema de aislamiento. 
    // Esto asegura que las apps antiguas no se rompan sin importar qué colecciones usen,
    // mientras mantenemos las nuevas colecciones estrictamente protegidas.
    match /{collection}/{document=**} {
      allow read, write: if isAuthenticated() && 
        !(collection in [
          'tbl_users', 'tbl_dashboards', 'tbl_systemSettings', 'tbl_managedClients',
          'vac_users', 'vac_weekly_data', 'vac_weekly_analysis', 'vac_config', 'vac_unes',
          'cpx_users', 'cpx_work_plans', 'cpx_indicators', 'cpx_reports'
        ]);
    }
  }
}
